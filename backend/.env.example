# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/hirelens
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/hirelens

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# JWT Configuration
JWT_SECRET=supersecretjwtkeythatshouldbechangedinproduction1234567890
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO / S3 Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_BUCKET_NAME=hirelens-resumes

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# General Configuration
APP_NAME=HireLens-AI
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
